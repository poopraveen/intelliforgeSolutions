# ─── Copy this file to .env.local and fill in your values ───────────────────
# Run: cp .env.local.example .env.local

# ── Gmail (Nodemailer) ────────────────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=pooprav26@gmail.com

# 16-character App Password (NOT your regular Gmail password)
# Steps to get it:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification (required)
#   3. Go to myaccount.google.com/apppasswords
#   4. Select app: Mail, device: Other → type "IntelliForge" → Generate
#   5. Copy the 16-char password shown (e.g. abcd efgh ijkl mnop → abcdefghijklmnop)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The Spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Service Account credentials (from Google Cloud Console)
# Steps:
#   1. Go to console.cloud.google.com → New Project "IntelliForge"
#   2. Enable APIs → search "Google Sheets API" → Enable
#   3. IAM & Admin → Service Accounts → Create → name it "intelliforge-sheets"
#   4. Keys tab → Add Key → JSON → download the file
#   5. Open the JSON file, copy client_email and private_key below
#   6. In your Google Sheet: Share → paste the client_email → Editor
GOOGLE_SERVICE_ACCOUNT_EMAIL=intelliforge-sheets@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot Token from @BotFather
# Steps:
#   1. Open Telegram → search @BotFather → /newbot
#   2. Name: IntelliForge Leads Bot
#   3. Username: intelliforge_leads_bot (must end in _bot)
#   4. Copy the token shown (looks like: 7123456789:AAHxxxxxxxxxxxxxx)
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID of your group/channel
# Steps:
#   1. Create a Telegram group (e.g. "IntelliForge Leads")
#   2. Add your bot to the group
#   3. Send any message in the group
#   4. Open: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   5. Find "chat":{"id": -123456789} — that negative number is your chat ID
TELEGRAM_CHAT_ID=-123456789
